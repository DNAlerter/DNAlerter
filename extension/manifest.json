{
  "manifest_version": 3,
  "name": "DNAlerter",
  "version": "1.0",
  "description": "Защита от рисков в публичных Wi-Fi: предупреждение при вводе пароля и блокировка сайтов с активной сессией",
  "permissions": [
    "cookies",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://127.0.0.1:4756/*",
    "http://localhost:4756/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_icon": "logo.png"
  },
  "icons": { "128": "logo.png" },
  "web_accessible_resources": [
    {
      "resources": [
        "blockpage.html",
        "blockpage.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}